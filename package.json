{
  "name": "roll",
  "version": "1.0.0",
  "description": "**从「那个谁」到「有人」——大学四年的互动叙事游戏。**",
  "main": "index.js",
  "dependencies": {
    "inkjs": "^2.4.0",
    "ssh2": "^1.17.0"
  },
  "scripts": {
    "ink:build": "node scripts/ink-build.mjs",
    "ink:check": "node scripts/ink-check.mjs",
    "ink:watch": "inklecate -w -o ink/military.json stories/military.ink",
    "vendor:ink": "node scripts/copy-vendor-ink.mjs",
    "predev": "npm run ink:build && npm run vendor:ink",
    "dev": "npx serve -l 3000",
    "build": "npm run ink:build && npm run vendor:ink",
    "prepare": "node scripts/install-git-hooks.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "deploy:remote": "node scripts/deploy-remote.mjs",
    "test": "npm run ink:check"
  },
